# Database connection used by Prisma.
DATABASE_URL=

# Privy app credentials.
# NEXT_PUBLIC_PRIVY_APP_ID is exposed to the browser.
# PRIVY_APP_SECRET is server-only and must not be prefixed with NEXT_PUBLIC.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Polygon RPC configuration.
# Use your own provider for POLYGON_RPC_URL in production.
# NEXT_PUBLIC_* values are bundled into client code for wallet/viem reads.
POLYGON_RPC_URL=
NEXT_PUBLIC_POLYGON_RPC_URL=
POLYGON_FALLBACK_RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon,https://polygon-bor-rpc.publicnode.com,https://polygon.drpc.org
NEXT_PUBLIC_POLYGON_FALLBACK_RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon,https://polygon-bor-rpc.publicnode.com,https://polygon.drpc.org
POLYGON_CHAIN_ID=137
NEXT_PUBLIC_POLYGON_CHAIN_ID=137

# Polymarket API endpoints.
# Server-only variants are used by API routes; NEXT_PUBLIC_* variants are used by browser hooks/components.
CLOB_API_URL=https://clob.polymarket.com
NEXT_PUBLIC_CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
NEXT_PUBLIC_GAMMA_API_URL=https://gamma-api.polymarket.com
NEXT_PUBLIC_POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_BRIDGE_API_URL=https://bridge.polymarket.com
NEXT_PUBLIC_RELAYER_URL=https://relayer-v2.polymarket.com/
NEXT_PUBLIC_GEOBLOCK_API_URL=https://polymarket.com/api/geoblock
NEXT_PUBLIC_POLYMARKET_WEB_URL=https://polymarket.com

# Polygon mainnet token and protocol contract addresses.
# Keep server-only and NEXT_PUBLIC variants aligned when both exist.
USDC_E_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEXT_PUBLIC_USDC_E_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEXT_PUBLIC_USDC_E_DECIMALS=6
PUSD_CONTRACT_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
NEXT_PUBLIC_PUSD_CONTRACT_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
NEXT_PUBLIC_PUSD_DECIMALS=6
NEXT_PUBLIC_COLLATERAL_ONRAMP_ADDRESS=0x93070a847efef7f70739046a929d47a521f5b8ee
NEXT_PUBLIC_CTF_CONTRACT_ADDRESS=0x4d97dcd97ec945f40cf65f87097ace5ea0476045
NEXT_PUBLIC_CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
NEXT_PUBLIC_NEG_RISK_CTF_EXCHANGE_ADDRESS=0xC5d563A36AE78145C45a50134d48A1215220f80a
NEXT_PUBLIC_CTF_EXCHANGE_V2_ADDRESS=0xE111180000d2663C0091e4f400237545B87B996B
NEXT_PUBLIC_NEG_RISK_CTF_EXCHANGE_V2_ADDRESS=0xe2222d279d744050d28e00520010520000310F59
NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296
NEXT_PUBLIC_NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296
NEXT_PUBLIC_CTF_COLLATERAL_ADAPTER_ADDRESS=0xAdA100Db00Ca00073811820692005400218FcE1f
NEXT_PUBLIC_NEG_RISK_CTF_COLLATERAL_ADAPTER_ADDRESS=0xadA2005600Dec949baf300f4C6120000bDB6eAab

# Platform fee collection.
# PLATFORM_FEE_PRIVATE_KEY is server-only and signs automated refund transactions.
PLATFORM_FEE_WALLET=
PLATFORM_FEE_PRIVATE_KEY=
PLATFORM_FEE_BPS=100
MIN_TOTAL_USDC_MICROS=2000000

# Quote behavior.
# SLIPPAGE_BPS=200 means 2%; QUOTE_TTL_MS controls quote expiration.
SLIPPAGE_BPS=200
QUOTE_TTL_MS=60000

# Automatic refund controls.
# Gas buffer is in basis points; min net amount is in USDC micros.
AUTO_REFUND_ENABLED=true
AUTO_REFUND_MAX_PER_USER_PER_HOUR=3
AUTO_REFUND_GAS_BUFFER_BPS=2000
AUTO_REFUND_MIN_NET_USDC_MICROS=100000
POL_USD_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=polygon-ecosystem-token&vs_currencies=usd

# Optional remote signing endpoint and encryption key for stored builder credentials.
REMOTE_SIGNING_URL=
BUILDER_CREDENTIAL_ENCRYPTION_KEY=

# Demo-only switch. Do not enable in production.
NEXT_PUBLIC_DISABLE_GEOBLOCK_FOR_DEMO=false

# Logging.
LOG_LEVEL=info
CLIENT_LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info
SERVER_LOG_FILE_PATH=logs/server.log
CLIENT_LOG_FILE_PATH=logs/client.log
CLIENT_LOG_MAX_PER_USER_PER_MINUTE=120
